{
  "manifest_version": 3,
  "name": "PhishGuard",
  "version": "1.0",
  "description": "LLM-based phishing email detector and explainer.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://phishguard-production-93c3.up.railway.app/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"]
    }
  ]
}
