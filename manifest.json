{
  "manifest_version": 3,
  "name": "JESTER",
  "version": "1.0",
  "description": "LLM-based phishing email detector and explainer.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://phishguard-production-93c3.up.railway.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
